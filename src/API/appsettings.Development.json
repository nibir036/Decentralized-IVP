{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ]
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=divp_db;Username=divp_user;Password=divp_secret"
  },
  "AcaPy": {
    "AdminUrl": "http://localhost:8001",
    "AdminApiKey": "divp_admin_api_key",
    "MultitenantJwtSecret": "super_secret_jwt_key_change_in_prod",
    "WebhookApiKey": "divp_webhook_secret"
  },
  "DidResolver": {
    "BaseUrl": "http://localhost:8080"
  },
  "Jwt": {
    "Issuer": "https://divp.local",
    "Audience": "https://divp.local",
    "SecretKey": "dev_jwt_secret_min_32_chars_long_x",
    "AccessTokenExpiryMinutes": 15,
    "RefreshTokenExpiryDays": 7
  },
  "AllowedHosts": "*"
}